<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <AssemblyName>Paradise.Rendering.Pbr</AssemblyName>
    <RootNamespace>Paradise.Rendering.Pbr</RootNamespace>
    <PackageId>Paradise.Rendering.Pbr</PackageId>
    <Title>Paradise.Rendering.Pbr</Title>
    <Authors>ParadiseEngine</Authors>
    <Description>PBR metallic-roughness scene renderer: Slang-compiled Cook-Torrance shader with reflection-validated uniforms, GLB mesh upload, KTX2 material cache, and a per-frame command-stream emitter over the WebGPU backend.</Description>
    <Copyright>ParadiseEngine</Copyright>
    <PackageProjectUrl>https://github.com/ParadiseEngine/ParadiseEngine</PackageProjectUrl>
    <RepositoryUrl>https://github.com/ParadiseEngine/ParadiseEngine</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageTags>pbr;rendering;webgpu;gltf;nativeaot;game-dev</PackageTags>
    <!-- AOT-clean: reflection-validated uniforms are explicit offset tables, not System.Reflection. -->
    <IsTrimmable>true</IsTrimmable>
    <IsAotCompatible>true</IsAotCompatible>
  </PropertyGroup>

  <Import Project="$(MSBuildThisFileDirectory)../Slang.targets" />

  <ItemGroup>
    <SlangShader Include="Shaders/**/*.slang" />
  </ItemGroup>

  <ItemGroup>
    <!-- The concrete WebGPU backend is referenced directly: Paradise.Rendering deliberately has
         no IRenderer abstraction yet (YAGNI — one backend). When a second backend exists, the
         resource+submit surface this project consumes is the interface to extract. -->
    <ProjectReference Include="..\Paradise.Rendering\Paradise.Rendering.csproj" />
    <ProjectReference Include="..\Paradise.Rendering.WebGPU\Paradise.Rendering.WebGPU.csproj" />
    <ProjectReference Include="..\Paradise.Assets.Gltf\Paradise.Assets.Gltf.csproj" />
    <ProjectReference Include="..\Paradise.Assets.Textures\Paradise.Assets.Textures.csproj" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="Paradise.Rendering.Pbr.Test" />
  </ItemGroup>

</Project>
