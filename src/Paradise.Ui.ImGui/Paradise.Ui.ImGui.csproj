<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <AssemblyName>Paradise.Ui.ImGui</AssemblyName>
    <RootNamespace>Paradise.Ui.ImGui</RootNamespace>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <LangVersion>latest</LangVersion>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <Title>Paradise.Ui.ImGui</Title>
    <PackageId>Paradise.Ui.ImGui</PackageId>
    <Description>Dear ImGui overlay integration for Paradise Engine: ImGui.NET-driven debug UI rendered through the WebGPU backend.</Description>
    <PackageTags>imgui;ui;overlay;webgpu;game-dev</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="ImGui.NET" />
    <PackageReference Include="WebGPUSharp" />
  </ItemGroup>
</Project>
